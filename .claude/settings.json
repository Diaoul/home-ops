{
  "permissions": {
    "allow": [
      "Bash(bash scripts/kubeconform.sh)",
      "Bash(bash scripts/sops-mismatch.sh)",
      "Bash(dig *)",
      "Bash(flux get *)",
      "Bash(flux logs *)",
      "Bash(flux-local *)",
      "Bash(gh api *)",
      "Bash(gh run watch *)",
      "Bash(gh status *)",
      "Bash(kubeconform *)",
      "Bash(kubectl cnpg status postgres18 -n database 2>&1)",
      "Bash(kubectl describe *)",
      "Bash(kubectl exec -n kube-system ds/cilium -- cilium bgp peers)",
      "Bash(kubectl exec -n kube-system ds/cilium -- cilium status --brief)",
      "Bash(kubectl get *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl rollout status *)",
      "Bash(kubectl top *)",
      "Bash(mise list *)",
      "Bash(nslookup *)",
      "Bash(talosctl get *)",
      "Bash(talosctl logs *)",
      "Bash(talosctl ls *)",
      "Bash(talosctl read *)",
      "Bash(talosctl usage *)",
      "Bash(yamllint *)",
      "Bash(rtk gh api *)",
      "Bash(rtk gh run watch *)",
      "Bash(rtk gh status *)",
      "Bash(rtk kubectl cnpg status postgres18 -n database 2>&1)",
      "Bash(rtk kubectl describe *)",
      "Bash(rtk kubectl exec -n kube-system ds/cilium -- cilium bgp peers)",
      "Bash(rtk kubectl exec -n kube-system ds/cilium -- cilium status --brief)",
      "Bash(rtk kubectl get *)",
      "Bash(rtk kubectl logs *)",
      "Bash(rtk kubectl rollout status *)",
      "Bash(rtk kubectl top *)",
      "Bash(rtk proxy kubectl get *)",
      "Bash(rtk yamllint *)",
      "Bash(curl * https://alertmanager.diaoul.io*)",
      "Bash(curl * https://vmsingle.diaoul.io*)",
      "Bash(curl * https://vmalert.diaoul.io*)",
      "Bash(rtk curl * https://alertmanager.diaoul.io*)",
      "Bash(rtk curl * https://vmsingle.diaoul.io*)",
      "Bash(rtk curl * https://vmalert.diaoul.io*)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:autobrr.com)",
      "WebFetch(domain:gateway.envoyproxy.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:hub.docker.com)",
      "WebFetch(domain:kubesearch.dev)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:recyclarr.dev)",
      "WebFetch(domain:torrentleech.org)",
      "WebFetch(domain:trash-guides.info)",
      "WebFetch(domain:wiki.torrentleech.org)",
      "WebFetch(domain:www.authelia.com)",
      "WebFetch(domain:www.talos.dev)",
      "WebSearch"
    ],
    "deny": [
      "Bash(age *)",
      "Bash(kubectl describe secret *)",
      "Bash(kubectl describe secrets *)",
      "Bash(kubectl get secret *)",
      "Bash(kubectl get secrets *)",
      "Bash(sops *)",
      "Bash(rtk kubectl describe secret *)",
      "Bash(rtk kubectl describe secrets *)",
      "Bash(rtk kubectl get secret *)",
      "Bash(rtk kubectl get secrets *)",
      "Read(.venv/)",
      "Read(talos/clusterconfig)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command'); if echo \"$cmd\" | grep -qE '^(rtk )?kubectl[[:space:]]+-n[[:space:]]+'; then echo '{\"decision\":\"block\",\"reason\":\"kubectl -n flag must be placed at the end, not immediately after kubectl\"}'; fi"
          }
        ]
      }
    ]
  }
}
