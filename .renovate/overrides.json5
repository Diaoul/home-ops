{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Use loose versioning for lldap date-based tags",
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/lldap/lldap"],
      versioning: "loose",
    },
    {
      description: "Restrict frigate to semver tags only",
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/blakeblackshear/frigate"],
      allowedVersions: "/^[0-9]+\\.[0-9]+\\.[0-9]+$/",
    },
  ],
}
